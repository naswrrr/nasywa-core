<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/my_logo"
            android:contentDescription="PlantShop Logo" />

        <TextView
            android:id="@+id/tvJudulJob"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/playfairdisplay_variablefont_wght"
            android:text="PlantShop Career"
            android:textColor="@color/plant_green"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeskripsiJob"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Wujudkan passion menanammu menjadi karir yang luar biasa"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp"
            android:text="Available Positions"
            android:textColor="@color/primary_dark"
            android:textStyle="bold"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/soft_grey"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:padding="16dp"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/titleJob1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Developer"
                    android:textColor="@color/plant_green"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_below="@id/titleJob1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full-time • Remote"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp" />
                <ImageView
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/plant_green" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/soft_grey"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:padding="16dp"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/titleJob2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UI/UX Designer"
                    android:textColor="@color/plant_green"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_below="@id/titleJob2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full-time • Jakarta"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp" />
                <ImageView
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/plant_green" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/soft_grey"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0">

            <RelativeLayout
                android:layout_width="match_parent"
                android:padding="16dp"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/titleJob3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plant Specialist"
                    android:textColor="@color/plant_green"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:layout_below="@id/titleJob3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contract • Greenhouse"
                    android:textColor="@color/text_grey"
                    android:textSize="12sp" />
                <ImageView
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/plant_green" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Join Our Community"
            android:textAllCaps="false"
            app:backgroundTint="@color/plant_green"
            app:cornerRadius="25dp" />

    </LinearLayout>
</ScrollView>